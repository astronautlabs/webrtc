{
    "compilerOptions": {
        "experimentalDecorators": true,
        "emitDecoratorMetadata": true,
        "declaration": true,
        "sourceMap": true,
        "target": "ES2016",
        "module": "nodenext",
        "lib": ["DOM", "DOM.AsyncIterable", "DOM.Iterable", "ES2025"],
        "moduleResolution": "nodenext",
        "esModuleInterop": true,
        "outDir": "dist",
        "rootDir": "lib"
    },
    "include": [
        "lib/**/*.ts"
    ]
}