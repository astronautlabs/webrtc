{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Launch Tests (and Debug C++)",
            "type": "cppdbg",
            "request": "launch",
            "program": "/home/liam/.nvm/versions/node/v18.19.0/bin/node",
            "args": ["${workspaceFolder}/node_modules/.bin/jest", "--runInBand", "rtpsender"],
            "stopAtEntry": false,
            "cwd": "${fileDirname}",
            "environment": [],
            "externalConsole": false,
            "MIMode": "gdb",
            "sourceFileMap": {
                "./../../download/src": "${workspaceFolder}/build/external/libwebrtc/download/src"
            },
            "setupCommands": [
                {
                    "description": "Enable pretty-printing for gdb",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                },
                {
                    "description":  "Set Disassembly Flavor to Intel",
                    "text": "-gdb-set disassembly-flavor intel",
                    "ignoreFailures": true
                }
            ]
        },
    {
        "name": "(gdb) Attach",
        "type": "cppdbg",
        "request": "attach",
        "program": "${workspaceFolder}/build/Debug/wrtc.node",
        "MIMode": "gdb",
        "setupCommands": [
            {
                "description": "Enable pretty-printing for gdb",
                "text": "-enable-pretty-printing",
                "ignoreFailures": true
            },
            {
                "description":  "Set Disassembly Flavor to Intel",
                "text": "-gdb-set disassembly-flavor intel",
                "ignoreFailures": true
            }
        ]
    },
    {
        "type": "node",
        "request": "launch",
        "name": "Launch Tests (and debug Javascript)",
        "skipFiles": [
            "<node_internals>/**"
        ],
        "program": "${workspaceFolder}/node_modules/.bin/jest",
        "args": ["--runInBand", "rtpsender"],
        "preLaunchTask": "tsc: build - tsconfig.json",
        "outFiles": [
            "${workspaceFolder}/dist/**/*.js"
        ]
    }
    ]
}