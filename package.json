{
  "name": "@astronautlabs/webrtc",
  "description": "Standards-compliant WebRTC implementation for Node",
  "keywords": [
    "webrtc",
    "p2p",
    "peer"
  ],
  "publishConfig": {
    "access": "public"
  },
  "version": "0.6.0",
  "maintainers": [
    "William Lahti <liam@astronautlabs.com>"
  ],
  "author": "Alan K <ack@modeswitch.org> (http://blog.modeswitch.org)",
  "homepage": "https://github.com/astronautlabs/webrtc",
  "bugs": "https://github.com/astronautlabs/webrtc/issues",
  "license": "BSD-2-Clause",
  "repository": {
    "type": "git",
    "url": "https://github.com/astronautlabs/webrtc.git"
  },
  "main": "dist/nodejs/index.js",
  "browser": "dist/browser/index.js",
  "twine": {
    "distributionUrl": "https://webrtc.astrocdn.com",
    "moduleName": "wrtc"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@astronautlabs/twine": "^1.1.3",
    "bindings": "^1.5.0",
    "cmake-js": "^8.0.0",
    "libyuv": "^0.2.2",
    "nan": "^2.26.2",
    "node-addon-api": "^8.9.0"
  },
  "optionalDependencies": {
    "domexception": "^1.0.1"
  },
  "devDependencies": {
    "@fidm/x509": "^1.2.1",
    "@rollup/plugin-commonjs": "^29.0.0",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@types/chai": "^4.3.1",
    "@types/debug": "^4.1.13",
    "@types/jest": "^30.0.0",
    "@types/js-yaml": "^4.0.9",
    "@types/jsdom": "^28.0.3",
    "@types/mkdirp": "^2.0.0",
    "@types/mocha-sugar-free": "^1.4.8",
    "@types/node": "^20",
    "@types/q": "^1.5.8",
    "@types/server-destroy": "^1.0.4",
    "@types/simple-peer": "^9.11.4",
    "@types/which": "^2.0.1",
    "@types/ws": "^8.18.1",
    "@web/dev-server-esbuild": "^1.0.4",
    "@web/dev-server-rollup": "^0.6.4",
    "@web/test-runner": "^0.20.2",
    "@web/test-runner-puppeteer": "^0.18.0",
    "aws-sdk": "^2.2.10",
    "browserify-middleware": "^8.1.1",
    "canvas": "^3.2.3",
    "chai": "^4.3.6",
    "debug": "^4.4.3",
    "dotenv": "^16.0.1",
    "electron": "^43.1.1",
    "eslint": "^4.14.0",
    "glob": "^13.0.6",
    "jest": "^30.4.2",
    "js-yaml": "^3.13.0",
    "jsdom": "^29.1.1",
    "minimatch": "^10.2.5",
    "mkdirp": "^3.0.1",
    "q": "^1.5.1",
    "rimraf": "^6.1.3",
    "rollup-plugin-node-polyfills": "^0.2.1",
    "server-destroy": "^1.0.1",
    "simple-peer": "~9.11.1",
    "ts-jest": "^29.4.11",
    "ts-node": "^10.9.2",
    "tslib": "^2.8.1",
    "typescript": "^5.9.3",
    "which": "^2.0.2",
    "ws": "^8.21.0",
    "wtfnode": "^0.10.1"
  },
  "scripts": {
    "install": "twine install",
    "build": "npm run build:native && npm run build:tsc",
    "build:tsc": "tsc -b",
    "build:native": "npm run build:native:libwebrtc && npm run build:native:addon",
    "build:native:debug": "npm run build:native:libwebrtc:debug && npm run build:native:addon:debug",
    "build:native:libwebrtc": "ts-node scripts/build-webrtc.ts",
    "build:native:libwebrtc:debug": "ts-node scripts/build-webrtc.ts Debug",
    "build:native:addon": "ts-node scripts/build-addon.ts",
    "build:native:addon:debug": "ts-node scripts/build-addon.ts Debug",
    "build:ci-docker": "npm run build:ci-docker:build && npm run build:ci-docker:push",
    "build:ci-docker:build": "docker build . -t astronautlabs/ci-webrtc:latest",
    "build:ci-docker:push": "docker push astronautlabs/ci-webrtc:latest",
    "publish:binary": "twine publish",
    "prepublishOnly": "npm run test",
    "test": "node --expose-gc node_modules/jest/bin/jest.js --showSeed",
    "test:gdb": "gdb -ex run --args node --expose-gc node_modules/jest/bin/jest.js --showSeed --runInBand",
    "test:gdb:verbose": "LOG=1 DEBUG=simple-peer,webrtc NODE_WEBRTC_LOGGING=1 gdb -ex run --args node --expose-gc node_modules/jest/bin/jest.js --showSeed",
    "test:wtf": "wtfnode --expose-gc node_modules/jest/bin/jest.js --showSeed",
    "test:cpp": "node --expose-gc --enable-source-maps dist/nodejs/test/cpp-test.js",
    "test:vgdb": "cd build/external/libwebrtc/build/Debug && vgdb --args node node_modules/jest/bin/jest.js",
    "test:browser": "ts-node test/browser/test.ts",
    "test:electron": "electron dist/nodejs/test/electron/index.js",
    "wpt:init": "git submodule update --init --recursive",
    "wpt:reset": "rimraf ./web-platform-tests && npm run wpt:init",
    "wpt:test": "node dist/nodejs/test/web-platform-tests/run-wpts.js",
    "wpt:test:debug": "node --inspect-brk dist/nodejs/test/web-platform-tests/run-wpts.js",
    "wpt:test:debug:native": "node dist/nodejs/test/web-platform-tests/run-wpts.js --native-debug",
    "wpt:test:gdb": "cd build/external/libwebrtc/build/Debug && gdb --args node ../../../../../dist/nodejs/test/web-platform-tests/run-wpts.js",
    "wpt:update": "git submodule update --recursive --remote --force && cd web-platform-tests && python wpt.py manifest --path ../lib/nodejs/test/web-platform-tests/wpt-manifest.json"
  },
  "allowScripts": {
    "canvas@3.2.3": true,
    "electron@43.1.1": true,
    "esbuild@0.27.7": true,
    "libyuv@0.2.2": true,
    "puppeteer@24.43.1": true,
    "unrs-resolver@1.12.2": true
  }
}
