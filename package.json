{
  "name": "@astronautlabs/webrtc",
  "description": "Standards-compliant WebRTC implementation for Node",
  "keywords": [
    "webrtc",
    "p2p",
    "peer"
  ],
  "publishConfig": {
    "access": "public"
  },
  "version": "0.6.0",
  "maintainers": [
    "William Lahti <liam@astronautlabs.com>"
  ],
  "author": "Alan K <ack@modeswitch.org> (http://blog.modeswitch.org)",
  "homepage": "https://github.com/astronautlabs/webrtc",
  "bugs": "https://github.com/astronautlabs/webrtc/issues",
  "license": "BSD-2-Clause",
  "repository": {
    "type": "git",
    "url": "https://github.com/astronautlabs/webrtc.git"
  },
  "main": "dist/nodejs/index.js",
  "browser": "dist/browser/index.js",
  "twine": {
    "distributionUrl": "https://webrtc.astrocdn.com",
    "moduleName": "wrtc"
  },
  "engines": {
    "node": "^18.0.0 || ^19.0.0"
  },
  "dependencies": {
    "@astronautlabs/segfault-handler": "^1.0.0",
    "@astronautlabs/twine": "^1.1.3",
    "bindings": "^1.5.0",
    "cmake-js": "^8.0.0",
    "libyuv": "^0.2.1",
    "nan": "^2.26.2",
    "node-addon-api": "^8.9.0",
    "node-cmake": "2.5.1"
  },
  "optionalDependencies": {
    "domexception": "^1.0.1"
  },
  "devDependencies": {
    "@fidm/x509": "^1.2.1",
    "@types/chai": "^4.3.1",
    "@types/debug": "^4.1.13",
    "@types/js-yaml": "^4.0.9",
    "@types/jsdom": "^28.0.3",
    "@types/mocha-sugar-free": "^1.4.8",
    "@types/node": "^20",
    "@types/q": "^1.5.8",
    "@types/server-destroy": "^1.0.4",
    "@types/simple-peer": "^9.11.4",
    "@types/which": "^2.0.1",
    "aws-sdk": "^2.2.10",
    "browserify-middleware": "^8.1.1",
    "canvas": "^3.2.3",
    "chai": "^4.3.6",
    "cross-env": "^5.1.4",
    "debug": "^4.4.3",
    "dotenv": "^16.0.1",
    "eslint": "^4.14.0",
    "express": "^4.16.2",
    "jest": "^30.4.2",
    "js-yaml": "^3.13.0",
    "jsdom": "^29.1.1",
    "karma": "^6.3.16",
    "karma-browserify": "^5.1.2",
    "karma-chrome-launcher": "^2.2.0",
    "karma-firefox-launcher": "^1.1.0",
    "karma-tap": "^4.1.4",
    "karma-tap-pretty-reporter": "^4.1.0",
    "minimatch": "^10.2.5",
    "minimist": "1.2.6",
    "mocha": "^5.2.0",
    "mocha-sugar-free": "^1.4.0",
    "node-fetch": "^2.5.0",
    "q": "^1.5.1",
    "recursive-copy": "^2.0.10",
    "rimraf": "^2.6.2",
    "semver": "^5.5.0",
    "server-destroy": "^1.0.1",
    "simple-peer": "~9.11.1",
    "tap-spec": "^5.0.0",
    "tape": "^4.9.1",
    "temp": "^0.9.0",
    "ts-jest": "^29.4.11",
    "ts-node": "^10.9.2",
    "tslib": "^2.8.1",
    "typescript": "^5.9.3",
    "which": "^2.0.2",
    "ws": "^5.2.0",
    "wtfnode": "^0.10.1",
    "zone.js": "^0.11.8"
  },
  "scripts": {
    "build:tsc": "tsc -b",
    "install": "twine install",
    "build:dev": "node scripts/build-from-source.mjs workspace",
    "build:native": "node scripts/build-from-source.mjs",
    "build:native:release": "npm run configure && ncmake build -j 12",
    "build:native:debug": "npm run configure:debug && ncmake build --debug -j 12",
    "clean": "ncmake clean",
    "configure:debug": "ncmake configure --debug",
    "configure": "ncmake configure",
    "install-example": "node scripts/install-example.js",
    "lint": "eslint lib/*.js lib/**/*.js test/*.js test/**/*.js karma/*.js scripts/*.js",
    "publish:binary": "twine publish",
    "prepublishOnly": "npm run test",
    "test": "node --expose-gc node_modules/.bin/jest",
    "test:gdb": "gdb -ex run --args node --expose-gc node_modules/.bin/jest",
    "test:gdb:verbose": "LOG=1 DEBUG=simple-peer,webrtc NODE_WEBRTC_LOGGING=1 gdb -ex run --args node --expose-gc node_modules/.bin/jest",
    "test:wtf": "wtfnode node_modules/.bin/jest --expose-gc",
    "test:cpp": "node --expose-gc --enable-source-maps dist/nodejs/test/cpp-test.js",
    "test:vgdb": "cd build/external/libwebrtc/build/Debug && vgdb --args node ../../../../../dist/nodejs/test/test.js",
    "test:browsers": "cross-env BROWSER=chrome node scripts/karma.js && cross-env BROWSER=firefox node scripts/karma.js",
    "test:electron": "electron test/electron",
    "wpt:init": "git submodule update --init --recursive",
    "wpt:reset": "rimraf ./web-platform-tests && npm run wpt:init",
    "wpt:test": "node dist/nodejs/test/web-platform-tests/run-wpts.js",
    "wpt:test:debug": "node --inspect-brk dist/nodejs/test/web-platform-tests/run-wpts.js",
    "wpt:test:debug:native": "node dist/nodejs/test/web-platform-tests/run-wpts.js --native-debug",
    "wpt:test:gdb": "cd build/external/libwebrtc/build/Debug && gdb --args node ../../../../../dist/nodejs/test/web-platform-tests/run-wpts.js",
    "wpt:update": "git submodule update --recursive --remote --force && cd web-platform-tests && python wpt.py manifest --path ../lib/nodejs/test/web-platform-tests/wpt-manifest.json"
  }
}
